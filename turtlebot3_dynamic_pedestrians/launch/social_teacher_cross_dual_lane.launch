<launch>
  <arg name="model" default="$(env TURTLEBOT3_MODEL)" doc="model type [burger, waffle, waffle_pi]"/>
  <arg name="x_pos" default="-3.0"/>
  <arg name="y_pos" default="0.0"/>
  <arg name="z_pos" default="0.0"/>
  <arg name="yaw" default="0.0"/>
  <arg name="gui" default="true"/>

  <env name="GAZEBO_MODEL_PATH" value="$(find turtlebot3_dynamic_pedestrians)/models:$(optenv GAZEBO_MODEL_PATH)"/>

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find turtlebot3_dynamic_pedestrians)/worlds/social_teacher_cross_dual_lane.world"/>
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="headless" value="false"/>
    <arg name="debug" value="false"/>
  </include>

  <param
    name="robot_description"
    command="$(find xacro)/xacro --inorder $(find turtlebot3_description)/urdf/turtlebot3_$(arg model).urdf.xacro" />

  <node
    pkg="gazebo_ros"
    type="spawn_model"
    name="spawn_turtlebot3"
    args="-urdf -model turtlebot3_$(arg model) -x $(arg x_pos) -y $(arg y_pos) -z $(arg z_pos) -Y $(arg yaw) -param robot_description" />

  <node
    pkg="gazebo_ros"
    type="spawn_model"
    name="spawn_teacher_cross_dual_proxy_h1"
    args="-sdf -file $(find turtlebot3_dynamic_pedestrians)/models/pedestrian_lidar_proxy/model.sdf -model ped_teacher_cross_dual_proxy_h1 -x -3.05 -y 0.75 -z 0.0 -Y 0.0" />

  <node
    pkg="gazebo_ros"
    type="spawn_model"
    name="spawn_teacher_cross_dual_proxy_h2"
    args="-sdf -file $(find turtlebot3_dynamic_pedestrians)/models/pedestrian_lidar_proxy/model.sdf -model ped_teacher_cross_dual_proxy_h2 -x 3.05 -y -0.75 -z 0.0 -Y 3.14" />

  <node
    pkg="gazebo_ros"
    type="spawn_model"
    name="spawn_teacher_cross_dual_proxy_v1"
    args="-sdf -file $(find turtlebot3_dynamic_pedestrians)/models/pedestrian_lidar_proxy/model.sdf -model ped_teacher_cross_dual_proxy_v1 -x -0.55 -y -3.05 -z 0.0 -Y 1.57" />

  <node
    pkg="gazebo_ros"
    type="spawn_model"
    name="spawn_teacher_cross_dual_proxy_v2"
    args="-sdf -file $(find turtlebot3_dynamic_pedestrians)/models/pedestrian_lidar_proxy/model.sdf -model ped_teacher_cross_dual_proxy_v2 -x 0.55 -y 3.05 -z 0.0 -Y -1.57" />

  <node pkg="turtlebot3_dynamic_pedestrians" type="scan_visible_pedestrians.py" name="ped_teacher_cross_dual_proxy_h1_controller" output="screen">
    <param name="model_name" value="ped_teacher_cross_dual_proxy_h1"/>
    <param name="follow_actor" value="true"/>
    <param name="actor_name" value="ped_teacher_cross_dual_h1_visual"/>
    <param name="proxy_z" value="0.25"/>
    <param name="startup_delay" value="2.0"/>
    <param name="rate_hz" value="10.0"/>
  </node>

  <node pkg="turtlebot3_dynamic_pedestrians" type="scan_visible_pedestrians.py" name="ped_teacher_cross_dual_proxy_h2_controller" output="screen">
    <param name="model_name" value="ped_teacher_cross_dual_proxy_h2"/>
    <param name="follow_actor" value="true"/>
    <param name="actor_name" value="ped_teacher_cross_dual_h2_visual"/>
    <param name="proxy_z" value="0.25"/>
    <param name="startup_delay" value="2.0"/>
    <param name="rate_hz" value="10.0"/>
  </node>

  <node pkg="turtlebot3_dynamic_pedestrians" type="scan_visible_pedestrians.py" name="ped_teacher_cross_dual_proxy_v1_controller" output="screen">
    <param name="model_name" value="ped_teacher_cross_dual_proxy_v1"/>
    <param name="follow_actor" value="true"/>
    <param name="actor_name" value="ped_teacher_cross_dual_v1_visual"/>
    <param name="proxy_z" value="0.25"/>
    <param name="startup_delay" value="2.0"/>
    <param name="rate_hz" value="10.0"/>
  </node>

  <node pkg="turtlebot3_dynamic_pedestrians" type="scan_visible_pedestrians.py" name="ped_teacher_cross_dual_proxy_v2_controller" output="screen">
    <param name="model_name" value="ped_teacher_cross_dual_proxy_v2"/>
    <param name="follow_actor" value="true"/>
    <param name="actor_name" value="ped_teacher_cross_dual_v2_visual"/>
    <param name="proxy_z" value="0.25"/>
    <param name="startup_delay" value="2.0"/>
    <param name="rate_hz" value="10.0"/>
  </node>
</launch>
